# --- n8n Configuration ---
# Your domain (must match the URL you use to access n8n)
WEBHOOK_URL=https://n8n.yourdomain.com/

# --- Database (PostgreSQL) ---
POSTGRES_USER=n8n_user
POSTGRES_PASSWORD=change_this_to_a_secure_password
POSTGRES_DB=n8n
POSTGRES_HOST=postgres

# --- Performance & Security ---
# Set to 75% of your total RAM (e.g., 6GB for an 8GB VPS)
NODE_OPTIONS="--max-old-space-size=6144"

# Execution pruning (Prevents your server from crashing due to full logs)
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=168
EXECUTIONS_DATA_PRUNE_MAX_COUNT=10000

# Timezone
GENERIC_TIMEZONE=UTC
