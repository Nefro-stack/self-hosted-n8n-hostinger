# -------------------------------------------------------------
# n8n ENVIRONMENT VARIABLES TEMPLATE
# Rename this file to .env before deploying
# -------------------------------------------------------------

# Database Configuration
POSTGRES_USER=n8n_admin
POSTGRES_PASSWORD=ReplaceWithAStrongDatabasePassword!
POSTGRES_DB=n8n_production

# n8n Security Settings
# Generate a random 32 character string for encryption
N8N_ENCRYPTION_KEY=ReplaceWithRandomString123456789!

# Webhook URL (Replace with your Hostinger IP or Custom Domain)
WEBHOOK_URL=http://YOUR_VPS_IP:5678/
